mixin pagination(pagination, filterStatus)
    nav
      ul(class="pagination")
        if(pagination.currentPage > 1)
          li(class="page-item")
            button(
              type="button"
              class="page-link " 
              button-pagination = pagination.currentPage-1
              ) Trang trước
        - for (let i = 1; i <= pagination.totalPages; i++)
          li(class=`page-item ${ pagination.currentPage == i ? "active" : ""}`)
            button(type="button" class="page-link" button-pagination=i) #{i}
        if(pagination.currentPage < pagination.totalPages)
          li(class="page-item")
            button(type="button" class="page-link " button-pagination= pagination.currentPage+1) Kế tiếp
        if(pagination.currentPage < pagination.totalPages)
          li.page-item
            button.page-link(
              type="button"
              button-pagination=pagination.totalPages
            ) Trang cuối
    
