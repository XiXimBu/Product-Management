extends ../../layouts/default.pug
include ../../mixins/filter-product.pug
include ../../mixins/form-search.pug
include ../../mixins/pagination-product.pug
include ../../mixins/checkbox.pug

block main
  h1 Trang danh sách sản phẩm

  // ===== Bộ lọc =====
  .card.mb-3
    .card-header Bộ lọc và Tìm kiếm
    .card-body
      .row
        .col-6
          +filterStatus(filterStatus)
        .col-6
          +formSearch(keyword)

  // ===== Danh sách sản phẩm =====
  .card.mb-3
    .card-header
      .d-flex.justify-content-between.align-items-center
        span Danh sách sản phẩm
        if hasPermission && hasPermission('product_create')
          a(href=`${prefixAdmin}/products/create` class="btn btn-primary btn-sm") + Thêm sản phẩm

    .card-body

      // ===== Form change multi =====
      +checkbox(`${prefixAdmin}/products/change-multi`, 'PATCH')

      // ===== Table =====
      .table-wrapper
        table(class ="table table-hover table-sm" checkbox-multi)
          thead
              tr
                th
                  input(type="checkbox" data-checkall)
                th STT
                th Hình ảnh
                th Tiêu đề
                th Giá
                th Người tạo
                th Ngày tạo
                th Người cập nhật
                th Ngày cập nhật
                th Trạng thái
                th Hành động

          tbody
            each item, index in products
              tr
                td
                  input(
                    type="checkbox"
                    data-checkbox
                    value=item.id
                  )

                td #{((pagination && Number(pagination.skip)) || 0) + index + 1}

                td
                  img(
                    src=item.thumbnail
                    alt=item.title
                    width="100"
                  )

                td #{item.title}
                td #{item.price}$
                td= item.createdByName || '-'
                td= item.createdAtFormatted || '-'
                td= item.updatedByName || '-'
                td= item.updatedAtFormatted || '-'

                td
                  if item.status == "active"
                    button.badge.badge-success(
                      data-status=item.status
                      data-id=item._id
                      button-change-status
                    ) Hoạt động
                  else
                    button.badge.badge-danger(
                      data-status=item.status
                      data-id=item._id
                      button-change-status
                    ) Không hoạt động

                td
                  a.btn.btn-info.btn-sm(href=`${prefixAdmin}/products/detail/${item._id}`) Chi tiết
                  if hasPermission && hasPermission('product_edit')
                    a.btn.btn-warning.btn-sm.ml-1(href=`${prefixAdmin}/products/edit/${item._id}`) Sửa
                  if hasPermission && hasPermission('product_delete')
                    button.btn.btn-danger.btn-sm.ml-1(button-delete data-id=item._id) Xóa

      +pagination(pagination, filterStatus)

  // ===== Form change status ẩn =====
  form(
    action=""
    method="POST"
    id="form-change-status"
    data-path=`${prefixAdmin}/products/change-status`
  )
  form(
    action=""
    method="POST"
    id="form-delete"
    data-path=`${prefixAdmin}/products/delete`
  )
  //- script(src="/admin/script/trash.js")