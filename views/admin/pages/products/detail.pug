extends ../../layouts/default.pug

block main
  h1 Chi tiết sản phẩm

  .card.mb-3
    .card-header
      .d-flex.justify-content-between.align-items-center
        span Thông tin sản phẩm
        div
          a(href=`${prefixAdmin}/products/edit/${product._id}` class="btn btn-warning btn-sm mr-2") 
            | ✏️ Chỉnh sửa
          a(href=`${prefixAdmin}/products` class="btn btn-secondary btn-sm") 
            | ← Quay lại

    .card-body
      .row
        .col-md-4
          .text-center
            img(
              src=product.thumbnail
              alt=product.title
              class="img-fluid rounded shadow-sm"
              style="max-width: 100%; max-height: 400px;"
            )
        
        .col-md-8
          table.table.table-bordered
            tbody
              tr
                th(style="width: 200px;") Tiêu đề
                td #{product.title}
              
              tr
                th Slug
                td #{product.slug}
              
              tr
                th Giá
                td 
                  if product.discountPercentage > 0
                    span.text-muted.mr-2(style="text-decoration: line-through;") #{product.price}$
                    span.text-danger.font-weight-bold #{(product.price * (100 - product.discountPercentage) / 100).toFixed(2)}$
                    span.badge.badge-success.ml-2 -#{product.discountPercentage}%
                  else
                    span.font-weight-bold #{product.price}$
              
              tr
                th Số lượng tồn kho
                td 
                  if product.stock > 0
                    span.badge.badge-info #{product.stock} sản phẩm
                  else
                    span.badge.badge-danger Hết hàng
              
              tr
                th Trạng thái
                td
                  if product.status == "active"
                    span.badge.badge-success Hoạt động
                  else
                    span.badge.badge-secondary Không hoạt động
              
              tr
                th Vị trí
                td #{product.position}
              
              tr
                th Ngày tạo
                td #{product.createdAt ? new Date(product.createdAt).toLocaleString('vi-VN') : 'N/A'}
              
              tr
                th Ngày cập nhật
                td #{product.updatedAt ? new Date(product.updatedAt).toLocaleString('vi-VN') : 'N/A'}

  if product.description
    .card.mb-3
      .card-header Mô tả sản phẩm
      .card-body
        p #{product.description}
