doctype html
html
	head
		meta(charset="utf-8")
		meta(name="viewport" content="width=device-width, initial-scale=1")
		title #{pageTitle}
		link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css")
		link(rel="stylesheet" href="/admin/css/login.css")
	body(class="login-bg")
		.login-card
			.text-center
				h2 Đăng nhập Admin
				p.text-muted.mb-3 Đăng nhập để quản trị hệ thống

			include ../../partials/flash-messages.pug

			form(method="POST" action=`${prefixAdmin}/auth/login`)
				.form-group
					label(for="email") Email
					input#email.form-control(type="email" name="email" required placeholder="you@example.com")

				.form-group
					label(for="password") Mật khẩu
					input#password.form-control(type="password" name="password" required placeholder="Mật khẩu")

				button.btn.btn-login.btn-block(type="submit") Đăng nhập

			.login-footer
				small © #{new Date().getFullYear()} - Admin Panel

		script(src="https://cdn.jsdelivr.net/npm/jquery@3.5.1/dist/jquery.slim.min.js")
		script(src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js")
