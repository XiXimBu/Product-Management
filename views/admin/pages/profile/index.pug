extends ../../layouts/default.pug

block main
  .container.mt-4.profile-page
    .row
      .col-lg-4
        .profile-card
          .profile-avatar
            if user && user.avatar
              img(src=user.avatar alt='avatar')
            else
              img(src='/admin/images/default-avatar.png' alt='avatar')
            .upload-btn
              input#avatarInput(type='file' name='avatar' form='profileForm' accept='image/*' data-profile-editable disabled)
              label(for='avatarInput') Change avatar
          .profile-info
            h3= user && user.fullName ? user.fullName : 'Người dùng'
            p.role= user && user.roleName ? user.roleName : 'Role'
            p.email= user && user.email ? user.email : ''
          .profile-stats
            .stat
              strong 24
              span Orders
            .stat
              strong 8
              span Products
            .stat
              strong 12
              span Alerts
          .profile-actions
            button#editProfileBtn.btn.btn-primary(type='button') Edit profile
            a.btn.btn-outline(href=`${prefixAdmin}/dashboard`) Back

      .col-lg-8
        .card.profile-details
          .card-body
            h4.mb-3 Account details
            form#profileForm(method='post' action=`${prefixAdmin}/profile/update`)
              .form-row
                .form-group.col-md-6
                  label(for='fullname') Full name
                  input.form-control#fullname(type='text' name='fullName' value=(user && user.fullName) || '' data-profile-editable disabled)
                .form-group.col-md-6
                  label(for='phone') Phone
                  input.form-control#phone(type='text' name='phone' value=(user && user.phone) || '' data-profile-editable disabled)
              .form-row
                .form-group.col-md-6
                  label(for='email') Email
                  input.form-control#email(type='email' name='email' value=(user && user.email) || '' data-profile-editable disabled)
                .form-group.col-md-6
                  label(for='role') Role
                  input.form-control#role(type='text' name='role' readonly value=(user && user.roleName) || '')
              .form-group
                label(for='about') About
                textarea.form-control#about(name='about' rows='4' data-profile-editable disabled)= (user && user.about) || ''
              button.btn.btn-success.mt-2(type='submit') Save changes

        .card.mt-3.activity-card
          .card-body
            h5 Recent activity
            ul.activity-list
              li Activity: Logged in
              li Activity: Updated product #123
              li Activity: Password changed

block scripts
  script.
    (function(){
      var form = document.getElementById('profileForm');
      if(!form) return;
      var editBtn = document.getElementById('editProfileBtn');
      var saveBtn = form.querySelector("button[type='submit']");
      var editables = document.querySelectorAll('[data-profile-editable]');
      editables.forEach(function(i){ i.disabled = true; });
      if(saveBtn) saveBtn.disabled = true;
      if(editBtn){
        editBtn.addEventListener('click', function(e){
          e.preventDefault();
          editables.forEach(function(i){ i.disabled = false; });
          if(saveBtn) saveBtn.disabled = false;
          editBtn.classList.add('d-none');
        });
      }

      function showFlash(message, type){
        var container = document.getElementById('client-flash-container');
        if(!container){ console.log(message); return; }
        var div = document.createElement('div');
        div.className = 'alert alert-' + (type||'info') + ' alert-dismissible fade show';
        div.setAttribute('role','alert');
        div.innerHTML = (message || '') + '\n';
        var btn = document.createElement('button');
        btn.type = 'button'; btn.className = 'close'; btn.setAttribute('data-dismiss','alert'); btn.setAttribute('aria-label','Close');
        btn.innerHTML = '<span aria-hidden="true">&times;</span>';
        btn.addEventListener('click', function(){ div.parentNode && div.parentNode.removeChild(div); });
        div.appendChild(btn);
        container.appendChild(div);
        setTimeout(function(){ try{ div.parentNode && div.parentNode.removeChild(div); }catch(e){} }, 4000);
      }

      form.addEventListener('submit', function(e){
        e.preventDefault();
        if(!confirm('Save profile changes?')) return;
        if(saveBtn) saveBtn.disabled = true;
        var fd = new FormData(form);
        // send PATCH
        var endpoint = '#{prefixAdmin}/profile/update';
        fetch(endpoint, { method: 'PATCH', body: fd, credentials: 'same-origin' })
          .then(function(res){
            var ct = res.headers.get('content-type') || '';
            if(ct.indexOf('application/json') === -1){
              return res.text().then(function(text){ return { ok: false, body: { message: text || 'Invalid server response' } }; });
            }
            return res.json().then(function(body){ return { ok: res.ok, body: body }; });
          })
          .then(function(r){
            if(r.ok){
              showFlash(r.body && r.body.message ? r.body.message : 'Saved', 'success');
              // disable fields again
              editables.forEach(function(i){ i.disabled = true; });
              if(editBtn) editBtn.classList.remove('d-none');
            } else {
              showFlash(r.body && r.body.message ? r.body.message : 'Save failed', 'danger');
              if(saveBtn) saveBtn.disabled = false;
            }
          })
          .catch(function(err){ console.error(err); showFlash('Network error', 'danger'); if(saveBtn) saveBtn.disabled = false; });
      });
    })();
